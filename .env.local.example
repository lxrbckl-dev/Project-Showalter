# Copy to `.env.local` for local dev (gitignored). Values below are sane
# starting points that let `pnpm dev` and the test suite run end-to-end.

NODE_ENV=development
PORT=5827
BASE_URL=http://localhost:5827

# Dev DB lives at the repo root; safe to delete and recreate.
DATABASE_URL=file:./dev.db

# Placeholder — rotate for any dev session that actually exercises auth.
AUTH_SECRET=dev-only-change-me

ADMIN_EMAILS=dev@example.com
BOOTSTRAP_ENABLED=true

SEED_FROM_BRIEF=false
BOOKING_RATE_LIMIT_PER_HOUR=30

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:dev@example.com
