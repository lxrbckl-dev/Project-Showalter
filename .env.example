# Production env vars — copy this file to .env on the homelab and fill in
# every value. Dev values go in .env.local (see .env.local.example).

# ─── Runtime ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5827
BASE_URL=https://sawyer.showalter.business

# ─── Database ───────────────────────────────────────────────────────────────
# `file:` prefix is stripped by the app before being handed to better-sqlite3.
DATABASE_URL=file:/data/sqlite.db

# ─── Auth (Auth.js + WebAuthn; lands in Phase 1) ────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Admins are NOT env-driven. On a fresh deploy the first person to visit
# /admin/login claims the founding admin slot. Additional admins are added
# via single-use invite links generated from /admin/settings/admins. The old
# ADMIN_EMAILS + BOOTSTRAP_ENABLED variables were retired in #83.

# ─── Seeding (lands in Phase 2) ─────────────────────────────────────────────
# When true AND the target tables are empty, seed site_config / services /
# weekly_template_windows from Sawyer's brief data on first boot. Idempotent.
SEED_FROM_BRIEF=false

# ─── Rate limiting ──────────────────────────────────────────────────────────
# Per-IP rolling one-hour window on POST /api/bookings. Generous by default.
BOOKING_RATE_LIMIT_PER_HOUR=30

# ─── Docker Hub image pull ──────────────────────────────────────────────────
# Required — docker-compose.yml resolves the image as:
#   ${DOCKERHUB_USERNAME}/project-showalter:${SHOWALTER_IMAGE_TAG:-main}
DOCKERHUB_USERNAME=

# Optional — pin to a specific image tag (SHA or branch). Defaults to `main`.
# SHOWALTER_IMAGE_TAG=
