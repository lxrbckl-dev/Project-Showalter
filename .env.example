# Phase 0 — all env vars documented here. Production values land in the
# homelab's .env file; dev values go in .env.local (see .env.local.example).

# ─── Runtime ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5827
BASE_URL=https://showalter.business

# ─── Database ───────────────────────────────────────────────────────────────
# `file:` prefix is stripped by the app before being handed to better-sqlite3.
DATABASE_URL=file:/data/sqlite.db

# ─── Auth (Auth.js + WebAuthn; lands in Phase 1) ────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Comma-separated list of admin emails. Slot count = list length. Reconciled
# against the `admins` table on boot.
ADMIN_EMAILS=sshowalterservices@gmail.com,alex@lxrbckl.com

# Gates first-time passkey enrollment. Flip to `true` once to onboard admins,
# then back to `false` and restart to close the enrollment window.
BOOTSTRAP_ENABLED=false

# ─── Seeding (lands in Phase 2) ─────────────────────────────────────────────
# When true AND the target tables are empty, seed site_config / services /
# weekly_template_windows from Sawyer's brief data on first boot. Idempotent.
SEED_FROM_BRIEF=false

# ─── Rate limiting ──────────────────────────────────────────────────────────
# Per-IP rolling one-hour window on POST /api/bookings. Generous by default.
BOOKING_RATE_LIMIT_PER_HOUR=30

# ─── Web Push (lands in Phase 8) ────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:sshowalterservices@gmail.com

# ─── Umami analytics (Phase 12) ──────────────────────────────────────────────
# Self-hosted Umami runs as a separate container (see docker-compose.yml).
# These vars are optional — omit them in dev to disable tracking entirely.

# The full URL to the Umami tracking script served by your Umami instance.
# Example: https://analytics.showalter.business/script.js
NEXT_PUBLIC_UMAMI_SRC=

# The website ID generated in the Umami dashboard after adding a website.
# Visit your Umami instance → Settings → Websites → copy the ID here.
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# Postgres connection string for the Umami database container.
# Generate with: openssl rand -base64 32 (use result as the password component)
# Format: postgresql://umami:<password>@umami-db:5432/umami
UMAMI_DATABASE_URL=

# Secret used by Umami to sign session tokens.
# Generate with: openssl rand -base64 32
UMAMI_APP_SECRET=

# Password for the umami-db Postgres container.
# Generate with: openssl rand -base64 32
UMAMI_DB_PASSWORD=
